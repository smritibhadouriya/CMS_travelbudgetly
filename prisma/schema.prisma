/* ─────────────────────────────────────────────
   PACKAGE
   Source: package schema + filters doc.
   - Location split into city/state/region/continent/country
     (filters #1-3) while keeping legacy `location` string.
   - `duration` kept as display string ("4N/5D"); `durationNights`
     added as the parsed Int the range-slider filter (#8) needs.
   - `tripType` (honeymoon/group/family/solo) added, separate
     from `tags` which was already in use for something else.
   - `theme` (Cruise/Beach/Adventure/Wildlife) added — no prior field.
   - `category` added as the tier facet (Budget/Standard/Deluxe/
     Premium/Luxury) per filter #7. Kept legacy `tourCategory`
     as-is since it's likely already wired into existing code —
     did NOT merge the two, see chat note on why.
   - `features` ([{heading, content}]) and `faqs` ([{question,
     answer}]) added — content sections the doc schemas but the
     old model never captured.
   - `allRoutes` added alongside existing `allDestinations`
     (doc treats them as distinct fields).
   - price / originalPrice / discountPercent / reviewCount were
     already Int in the source schema — no change needed there,
     that part of the doc's "mandatory backend fix" was already done.
───────────────────────────────────────────── */
model Package {
  id      String @id @default(uuid())
  slug    String @unique
  title   String
  summary String @default("")

  location  String  @default("")
  city      String  @default("")
  state     String?
  region    String  @default("")
  continent String  @default("")
  country   String  @default("")

  duration       String @default("") // display, e.g. "4N/5D"
  durationNights Int    @default(0)  // parsed nights, for range filter

  all_destinations String @default("")
  all_routes      String @default("")
  destinations    Json   @default("[]")
  package_url String @default("")

  price           Int    @default(0)
 original_price  Int    @default(0)
  discount Int    @default(0)
  currency        String @default("INR")

  badge        String[] @default([])
  package_type  String   @default("") // Domestic | International
  type     String[] @default([]) // honeymoon, group, family, solo
  theme        String[] @default([]) // Cruise, Beach, Adventure, Wildlife
  category     String   @default("") // Budget, Standard, Deluxe, Premium, Luxury

  rating      Float @default(0)
  reviews Int   @default(0)

  images    String[] @default([])
  image_urls String[] @default([])

  itinerary Json @default("[]")
  features  Json @default("[]") // [{ heading, content }]
  faqs      Json @default("[]") // [{ question, answer }]

  inclusions String[] @default([])
  exclusions String[] @default([])


  isPublished    Boolean @default(false)
  isFeatured     Boolean @default(false)

  seo Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, isFeatured])
  @@index([price])
  @@index([tourCategory])
  @@index([location])
  @@index([country])
  @@index([packageType])
  @@index([category])
}